{
  "name": "bluetech/bluetech-sdk-php",
  "description": "SDK PHP oficial para API REST de BlueTech Software",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "BlueTech Software"
    }
  ],
  "require": {
    "php": ">=7.4",
    "psr/http-client": "^1.0",
    "psr/http-message": "^1.0",
    "psr/http-factory": "^1.0",
    "guzzlehttp/guzzle": "^7.10"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "phpstan/phpstan": "^1.11",
    "guzzlehttp/psr7": "^2.6"
  },
  "autoload": {
    "psr-4": {
      "Bluetech\\Sdk\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Bluetech\\Sdk\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
